<AnchorPane prefHeight="563.0" prefWidth="882.0" styleClass="fondo" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.programacion.trabajo_avanzada.controllers.LibrosController">
